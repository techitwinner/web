---
import PageSection from "./PageSection.astro";
interface Props {
    title: string;
}

const { title } = Astro.props;
const links = [
    {
        href: '/',
        i: '~/',
        label: 'Home'
    },
    {
        href: '/about/',
        i: '/about',
        label: 'About'
    },
    {
        href: '/posts/',
        i: '/posts',
        label: 'Posts'
    },
    {
        href: '/photography/',
        i: '/photography',
        label: 'Photography'
    },
    {
        href: '/projects/',
        i: '/projects',
        label: 'Projects'
    },
    {
        href: '/contact/',
        i: '/contact',
        label: 'Contact'
    }
]
const url = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
---

<PageSection role="nav">
    <nav class="navbar prose prose-slate dark:prose-invert">
        <h2 set:html={title}/>
        <slot/>
        <div class="links">
            {
                links.map((item) => (
                    <a class={`navitem font-mono ${url === item.href ? 'navitem-active' : ''}`} href={item.href}>{item.i}</a>
                ))
            }
        </div>
    </nav>
</PageSection>

<style>
    .navbar {
        display: flex;
        flex-direction: column;
        align-items: start;
        justify-content: start;
        .links {
            font-size: 16px;
            display: flex;
            flex-direction: row;
            align-items: center;
            justify-items: start;
            gap: 0.25rem;
            padding: 0.25rem;
            border-radius: 20px;
            background-color: rgba(var(--primary-color), 0.05);
            flex-wrap: wrap;
            .navitem {
                box-sizing: border-box;
                color: rgba(var(--text-base-color), 0.7);
                text-decoration: none;
                padding: 0.1rem 0.5rem;
                border-radius: var(--border-radius-full);
                transition: all 0.2s cubic-bezier(var(--easeOut));
            }
            .navitem:active {
                opacity: 0.7;
            }
            .navitem-active, .navitem:hover {
                color: white;
                background-color: rgba(var(--accent-color), 1);
            }
        }
    }
</style>