---
import PageSection from "./PageSection.astro";
interface Props {
    title: string;
}

const { title } = Astro.props;
const links = [
    {
        href: '/',
        label: 'Home'
    },
    {
        href: '/about',
        label: 'About'
    },
    {
        href: '/photography',
        label: 'Photography'
    },
    {
        href: '/projects',
        label: 'Projects'
    },
    {
        href: '/contact',
        label: 'Contact'
    }
]
const url = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : `${Astro.url.pathname}/`;
---

<PageSection role="nav">
    <nav class="navbar">
        <h1 set:html={title}/>
        <div class="links">
            {
                links.map((item) => (
                    <a class={`link ${url === item.href ? 'link-active' : ''}`} href={`${item.href}/`}>{item.href}</a>
                ))
            }
        </div>
    </nav>
</PageSection>

<style>
    .navbar {
        display: flex;
        flex-direction: column;
        align-items: start;
        justify-content: start;
        font-size: 20px;
        .links {
            font-size: 17px;
            display: flex;
            flex-direction: row;
            align-items: center;
            justify-items: start;
            gap: 0.75rem;
            padding: 0.35rem 0.75rem;
            border-radius: var(--border-radius);
            background-color: rgba(var(--primary-color), 0.05);
            flex-wrap: wrap;
        }
    }
</style>