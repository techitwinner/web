---
interface Props {
    title: string;
    url: string;
    desc: string;
    date: string;
    tags: string[];
}

const { title, url, desc, date, tags, } = Astro.props;

function formatDate(dateString:string) {
    if (dateString?.includes('T')) {
        return dateString?.split('T')[0];
    }
    return dateString;
}
---

<a href={url} class="t">
    <div class="title w-fit max-w-fit" style="text-overflow:ellipsis;line-clamp:2;">
        <p class="text-xl font-bold">{title}</p>
    </div>
    <div class="flex flex-row flex-wrap items-center gap-3">
        <p class="italic font-mono tracking-tighter" style="opacity: 0.75;font-size:16px;">{new Date(date).toDateString()}</p>
        <section class="badge" style="font-size:14px;display:flex;flex-direction:row;flex-wrap:wrap;gap:4px;">
            {tags?.map(tag => (
                    <p class="tag">
                        {tag}
                    </p>
            ))}
        </section>
    </div>
    <p style="font-size:16px;">{desc}</p>
</a>

<style>
    .t {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        color: rgba(var(--primary-color));
        text-decoration: none;
        border-radius: var(--border-radius-3xl);
        p {
            padding: 0;
            margin: 0;
        }
        opacity: 0.75;
        transition: all 0.3s cubic-bezier(var(--easeOut));
        .title {
            box-sizing: border-box;
            color: rgba(var(--accent-color));
            border-bottom: 2px dashed rgba(var(--accent-color),0);
        }
    }

    .t:hover {
        opacity: 1;
        .title {
            border-bottom: 2px dashed rgba(var(--accent-color));
        }
    }

    .t:active {
        opacity: 0.5;
        transition-duration: 0.1s; scale: 0.99;
    }

    .badge {
        .tag {
            @apply shadow;
            background-color: rgba(var(--secondary-color));
            border: 1px solid rgba(var(--primary-color),0.2);
            padding: .1rem .5rem;
            border-radius: var(--border-radius-full);
        }
    }
</style>