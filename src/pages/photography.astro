<style>
    /* Additional styles */
    .photography-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 0.5rem;
        .cell {
            border-radius: var(--border-radius);
        }
        .cell {
            img {
                display: flex;
                justify-content: center;
                align-items: center;
                width: 100%;
                height: 100%;
                object-fit: cover;
                border-radius: var(--border-radius);
            }
            transition: all 0.2s cubic-bezier(var(--easeOut));
        }
        .cell:hover {
            opacity:0.75;
        }
        .cell:active {
            scale: 0.95;
        }
    }
</style>