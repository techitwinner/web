---
import ContentSection from "../components/ContentSection.astro";
import PageSection from "../components/PageSection.astro";
import Layout from "../layouts/Layout.astro";

let countdownData = null;

// Handle POST request to set countdown data
if (Astro.request.method === 'POST') {
    const formData = await Astro.request.formData();
    const year = formData.get('year');
    const month = formData.get('month');
    const date = formData.get('date');
    const hour = formData.get('hour');
    const minute = formData.get('minute');
    const second = formData.get('second');
    const endtext = formData.get('endtext');

    countdownData = {
        time: `${year}-${month}-${date}T${hour}:${minute}:${second}`,
        endtext,
    };
}
---

<Layout
    title="Countdown | Techit Thawiang"
    description="Countdown"
    ogTitle="Techit's Countdown Page"
    ogDescription="Countdown"
    ogUrl="https://techit.win/countdown"
    navTitle={`Counting down to<br/><span id="translatedTargetDate2">null</span> at <span id="translatedTargetTime2">00:00</span>`}
    noIndex noNavbar noFooter
>
    <div class="items-center min-h-[calc(100vh-2rem)] flex flex-col justify-center w-full max-w-[56rem] p-4">
        <section class="w-full flex flex-col items-center justify-center">
            <div id="h1" class="hidden flex flex-col gap-4 text-center">
                <section>
                    <p class="text-2xl font-bold">Techit's Simple</p>
                    <p class="text-5xl md:text-7xl font-bold">Countdown</p>
                </section>
                <section class="text-start">
                    <p class="text-2xl font-bold text-center">How to Use</p>
                    <p><code class="text-pink-400">time</code> = <span>Countdown target time in the format <code>YYYY-MM-DDTHH:mm:ss</code>.</span></p>
                    <p>For example: <a href="https://techit.win/countdown/?time=2024-12-31T23:59:59"><code>https://techit.win/countdown/?time=2024-12-31T23:59:59</code></a> will be December 31, 2024 at 23:59:59</p>
                    <p><code class="text-pink-400">endtext</code> = <span>The text to be shown when the countdown ends.</span></p>
                    <p>For example: <a href="https://techit.win/countdown/?time=2024-12-31T23:59:59&endtext=Happy%20New%20Year!"><code>https://techit.win/countdown/?time=2024-12-31T23:59:59&amp;endtext=Happy%20New%20Year!</code></a></p>
                </section>
            </div>
            <div id="countdown-container" class="hidden w-full">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4">
                    <div class="dd">
                        <span id="countdown-days">0</span>
                        <p>Days</p>
                    </div>
                    <div class="hh">
                        <span id="countdown-hours">0</span>
                        <p>Hours</p>
                    </div>
                    <div class="mm">
                        <span id="countdown-minutes">0</span>
                        <p>Minutes</p>
                    </div>
                    <div class="ss">
                        <span id="countdown-seconds">0</span>
                        <p>Seconds</p>
                    </div>
                </div>
            </div>
            <div id="clock-container" class="hidden w-full">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4">
                    <div class="hh">
                        <span id="clock-hours">0</span>
                        <p>Hours</p>
                    </div>
                    <div class="mm">
                        <span id="clock-minutes">0</span>
                        <p>Minutes</p>
                    </div>
                    <div class="ss">
                        <span id="clock-seconds">0</span>
                        <p>Seconds</p>
                    </div>
                    <div class="ms">
                        <span id="clock-mseconds">0</span>
                        <p>Milli Seconds</p>
                    </div>
                </div>
            </div>
        </section>
        <section id="endtextParent" class="break-words">
            <p id="leftuntil" class="hidden text-2xl text-center w-full">left until <span id="translatedTargetDate">translatedTargetDate</span> at <span id="translatedTargetTime">translatedTargetTime</span></p>
            <p id="endtext" class="hidden anim-scaleIn text-5xl md:text-7xl text-center w-full">endtext</p>
        </section>
    </div>
</Layout>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const startCountdown = document.getElementById("submitButton");

        // Check if the submit button is available
        if (startCountdown) {
            console.log("Submit button clicked");
        }
    });
</script>

<style>
    #countdown-container, #clock-container {
        width: 100%;
    }
    #countdown-days, #countdown-hours, #countdown-minutes, #countdown-seconds {
        font-family: var(--font-family-monospace);
        display: flex;
        flex-direction: column;
        align-items: center;
        font-size: 8rem;
    }
    #clock-hours, #clock-minutes, #clock-seconds, #clock-mseconds {
        @apply text-6xl lg:text-8xl;
        font-family: var(--font-family-monospace);
        display: flex;
        flex-direction: column;
        align-items: center;
    }
    .dd, .hh, .mm, .ss, .ms {
        text-align: center;
    }
</style>

<script>
    // Get URL parameters for countdown time and end text
    const urlSearchParams = new URLSearchParams(window.location.search);
    const time = urlSearchParams.get('time');
    const endtext = urlSearchParams.get('endtext');

    const leftuntilElement = document.getElementById('leftuntil');
    const countdownContainer = document.getElementById('countdown-container');
    const translatedTargetDateElement = document.getElementById('translatedTargetDate');
    const translatedTargetTimeElement = document.getElementById('translatedTargetTime');
    const translatedTargetDateElement2 = document.getElementById('translatedTargetDate2');
    const translatedTargetTimeElement2 = document.getElementById('translatedTargetTime2');
    const endtextElement = document.getElementById('endtext');
    const endtextParentElement = document.getElementById('endtextParent');

    const asdijo1 = document.getElementById('h1');
    const noTimeElements = [asdijo1]; // Add other elements as needed

    noTimeElements.forEach(e => {
        if (!time) {
            e.classList.remove('hidden');
        }
    });

    if (time) {
        // Show countdown container and update text
        countdownContainer.classList.remove('hidden');
        leftuntilElement.classList.remove('hidden');
        endtextElement.classList.add('hidden');
        endtextParentElement.classList.add('mt-12');

        // Function to calculate time remaining
        function getTimeRemaining(endtime) {
            const total = Date.parse(endtime) - Date.now();
            const seconds = Math.floor((total / 1000) % 60);
            const minutes = Math.floor((total / 1000 / 60) % 60);
            const hours = Math.floor((total / (1000 * 60 * 60)) % 24);
            const days = Math.floor(total / (1000 * 60 * 60 * 24));
            
            return {
                total,
                days,
                hours,
                minutes,
                seconds
            };
        }

        const targetTime = new Date(time);

        // Format the target date
        const dateOptions = { year: 'numeric', month: 'long', day: 'numeric' };
        const formattedTargetDate = targetTime.toLocaleDateString(undefined, dateOptions);
        translatedTargetDateElement.textContent = formattedTargetDate;
        translatedTargetDateElement2.textContent = formattedTargetDate;

        // Format the target time
        const timeOptions = { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false };
        const formattedTargetTime = targetTime.toLocaleTimeString(undefined, timeOptions);
        translatedTargetTimeElement.textContent = formattedTargetTime;
        translatedTargetTimeElement2.textContent = formattedTargetTime;

        // Update countdown display
        function updateCountdown() {
            const t = getTimeRemaining(targetTime);

            document.getElementById('countdown-days').textContent = t.days;
            document.getElementById('countdown-hours').textContent = t.hours;
            document.getElementById('countdown-minutes').textContent = t.minutes;
            document.getElementById('countdown-seconds').textContent = t.seconds;

            // Check if countdown has finished
            if (t.total <= 0) {
                clearInterval(timeinterval);
                countdownContainer.classList.add('hidden');
                leftuntilElement.classList.add('hidden');
                endtextElement.classList.remove('hidden');
                endtextParentElement.classList.remove('mt-12');
                endtextParentElement.classList.add('mb-12');
                endtextElement.textContent = endtext || "Countdown has ended!"; // Default message if no endtext
            } else if (t.total = 1) {
                countdownContainer.classList.add('anim-scaleOut');
            };
        }

        const timeinterval = setInterval(updateCountdown, 1000);
        updateCountdown(); // Initial call to set the values immediately
    }
</script>
