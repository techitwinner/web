---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
---

<Layout title="Welcome to Astro.">
	<main>
		<h1>Embrace It</h1>
	</main>
</Layout>

<style is:global>
	main {
		margin: auto;
		padding: 1rem;
		width: 100%;
		max-width: 1024px;
		max-width: calc(100% - 2rem);
		color: white;
		font-size: 20px;
		line-height: 1.6;
	}
</style>